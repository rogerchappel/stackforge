{
  "name": "@rogerchappel/stackforge",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-friendly software project scaffolding CLI for apps, APIs, CLIs, and OSS packages.",
  "type": "module",
  "bin": {
    "stackforge": "./dist/index.js",
    "sf": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "docs:check": "node scripts/check-docs.mjs",
    "start": "node dist/index.js",
    "check:templates": "pnpm build && node scripts/check-template-registry.mjs",
    "smoke:init": "bash scripts/smoke-init.sh",
    "release:check": "pnpm run build && pnpm test && pnpm run smoke && pnpm run package:smoke",
    "test": "pnpm run build && node scripts/check-template-registry.mjs",
    "smoke": "pnpm run smoke:init",
    "package:smoke": "npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/stackforge.git"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ]
}
